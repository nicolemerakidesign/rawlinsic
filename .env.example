# Contact form email delivery via Resend (https://resend.com)
# Create a free account, verify a sending domain, and paste the API key here.
RESEND_API_KEY=

# Google reCAPTCHA v3 (https://www.google.com/recaptcha/admin)
# Create a new v3 site, add your domains (rawlinsic.com, www.rawlinsic.com, localhost),
# then paste the public site key below (exposed to the browser) and the secret key
# (server-only, used to verify tokens).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
